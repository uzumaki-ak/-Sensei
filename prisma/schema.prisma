generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  clerkUserId     String           @unique
  email           String           @unique
  name            String?
  imageUrl        String?
  industry        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bio             String?
  experience      Int?
  skills          String[]
  gmailToken      Json?
  telegramChatId  String?
  personas        Json?
  assessments     Assessment[]
  coverLetter     CoverLetter[]
  jobApplications JobApplication[]
  resumes         Resume[]         @relation("UserResumes")
  interviewHistories InterviewHistory[]
  primaryResumeId String?          @unique
  resume          Resume?          @relation("UserPrimaryResume", fields: [primaryResumeId], references: [id])
  industryInsight IndustryInsight? @relation(fields: [industry], references: [industry])
  githubAnalyses  GithubAnalysisHistory[]
  reverseRecruiterHistories ReverseRecruiterHistory[]
  companyIntelHistories CompanyIntelHistory[]
  dripCampaignHistories DripCampaignHistory[]
  offerCopilotHistories OfferCopilotHistory[]
  interviewMeetRooms InterviewMeetRoom[]
  ragKnowledgeChunks  RagKnowledgeChunk[]
  ragQueryHistories   RagQueryHistory[]
  multiAgentRuns      MultiAgentRun[]
  promptEvalRuns      PromptEvalRun[]
  personalChatSessions PersonalChatSession[]
  personalChatMessages PersonalChatMessage[]
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  category       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  improvementTip String?
  questions      Json[]
  quizScore      Float
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resume {
  id              String           @id @default(cuid())
  userId          String
  name            String           @default("My Resume")
  type            String?          // e.g., "AI Engineer", "Web Developer", "App Developer", "Blockchain"
  content         String
  atsScore        Float?
  feedback        String?
  isDefault       Boolean          @default(false)
  skills          String[]         // Extracted skills from resume
  experience      String?          // Brief summary of experience
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation("UserResumes", fields: [userId], references: [id], onDelete: Cascade)
  primaryFor      User?            @relation("UserPrimaryResume")
  jobApplications JobApplication[]

  @@index([userId])
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String
  content        String
  jobDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  companyName    String
  jobTitle       String
  status         String   @default("draft")
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IndustryInsight {
  id                String   @id @default(cuid())
  industry          String   @unique
  salaryRanges      Json[]
  growthRate        Float
  demandLevel       String
  topSkills         String[]
  marketOutlook     String
  keyTrends         String[]
  recommendedSkills String[]
  lastUpdated       DateTime @default(now())
  nextUpdate        DateTime
  users             User[]

  @@index([industry])
}

model JobListing {
  id             String           @id @default(cuid())
  title          String
  company        String
  description    String?
  sourceLink     String
  techStack      String[]
  recruiterEmail String?
  scrapedAt      DateTime         @default(now())
  applications   JobApplication[]
  interviewHistories InterviewHistory[]
}

model JobApplication {
  id             String     @id @default(cuid())
  userId         String
  jobId          String
  status         String     @default("Discovered")
  appliedAt      DateTime?
  draftEmail     String?
  emailSent      Boolean    @default(false)
  emailSentAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  attachmentId   String?
  attachmentName String?
  resumeId       String?    // The resume used for this application
  resume         Resume?    @relation(fields: [resumeId], references: [id])
  job            JobListing @relation(fields: [jobId], references: [id])
  user           User       @relation(fields: [userId], references: [id])
  githubAnalyses GithubAnalysisHistory[]
  reverseRecruiterHistories ReverseRecruiterHistory[]
  companyIntelHistories CompanyIntelHistory[]
  dripCampaignHistories DripCampaignHistory[]
  offerCopilotHistories OfferCopilotHistory[]
  interviewMeetRooms InterviewMeetRoom[]
  ragKnowledgeChunks  RagKnowledgeChunk[]
  ragQueryHistories   RagQueryHistory[]
  multiAgentRuns      MultiAgentRun[]
  promptEvalRuns      PromptEvalRun[]
  personalChatSessions PersonalChatSession[]

  @@index([userId])
  @@index([jobId])
  @@index([resumeId])
}

model ResumeAttachment {
  id            String   @id @default(cuid())
  userId        String
  applicationId String
  fileName      String
  fileType      String
  fileSize      Int
  fileData      String
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([applicationId])
}

model ResumeChat {
  id            String   @id @default(cuid())
  resumeId      String
  userId        String
  role          String   // "user" or "assistant"
  content       String
  createdAt     DateTime @default(now())

  @@index([resumeId])
  @@index([userId])
}

model InterviewHistory {
  id            String   @id @default(cuid())
  userId        String
  jobId         String
  createdAt     DateTime @default(now())
  projectContext String
  qaPairs       InterviewQA[]

  job           JobListing @relation(fields: [jobId], references: [id])
  user          User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([jobId])
}

model InterviewQA {
  id                 String   @id @default(cuid())
  interviewHistoryId String
  question           String
  userAnswer         String
  idealAnswer        String
  score              Int
  feedback           String

  interviewHistory   InterviewHistory @relation(fields: [interviewHistoryId], references: [id], onDelete: Cascade)

  @@index([interviewHistoryId])
}

model GithubAnalysisHistory {
  id                   String   @id @default(cuid())
  userId               String
  applicationId        String
  repoUrl              String
  missingSkills        String[]
  projectPlanMarkdown  String
  resumeRecommendation String
  createdAt            DateTime @default(now())

  user                 User           @relation(fields: [userId], references: [id])
  application          JobApplication @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
}

model ReverseRecruiterHistory {
  id              String   @id @default(cuid())
  userId          String
  applicationId   String
  targetName      String
  targetEmail     String
  subject         String
  body            String
  createdAt       DateTime @default(now())

  user            User           @relation(fields: [userId], references: [id])
  application     JobApplication @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
}

model CompanyIntelHistory {
  id                  String   @id @default(cuid())
  userId              String
  applicationId       String
  manualLinks         String[]
  intel               Json
  talkingPointsMarkdown String?
  recentNews          Json?
  createdAt           DateTime @default(now())

  user                User           @relation(fields: [userId], references: [id])
  application         JobApplication @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
}

model DripCampaignHistory {
  id               String   @id @default(cuid())
  userId           String
  applicationId    String
  sequenceMarkdown String
  createdAt        DateTime @default(now())

  user             User           @relation(fields: [userId], references: [id])
  application      JobApplication @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
}

model OfferCopilotHistory {
  id                        String   @id @default(cuid())
  userId                    String
  applicationId             String
  offerInput                Json
  playbook                  Json
  compensation              Json
  negotiationScriptMarkdown String?
  createdAt                 DateTime @default(now())

  user                      User           @relation(fields: [userId], references: [id])
  application               JobApplication @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
}

model InterviewMeetRoom {
  id            String   @id @default(cuid())
  code          String   @unique
  ownerUserId   String
  applicationId String
  candidateName String?
  candidateContext String?
  companyContext String?
  jobContext    Json?
  status        String   @default("WAITING")
  maxQuestions  Int      @default(8)
  questionCount Int      @default(0)
  evaluation    Json?
  evaluatedAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User           @relation(fields: [ownerUserId], references: [id])
  application   JobApplication @relation(fields: [applicationId], references: [id])
  turns         InterviewMeetTurn[]

  @@index([ownerUserId])
  @@index([applicationId])
  @@index([status])
}

model InterviewMeetTurn {
  id        String   @id @default(cuid())
  roomId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  room      InterviewMeetRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([role])
}

model RagKnowledgeChunk {
  id          String   @id @default(cuid())
  userId      String
  applicationId String?
  sourceType  String
  sourceLabel String
  chunkText   String
  embedding   Json
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id])
  application JobApplication? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
  @@index([sourceType])
}

model RagQueryHistory {
  id              String   @id @default(cuid())
  userId          String
  applicationId   String?
  question        String
  answer          String
  citations       Json?
  retrievedChunks Json?
  providerTrace   Json?
  createdAt       DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  application     JobApplication? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
  @@index([createdAt])
}

model MultiAgentRun {
  id               String   @id @default(cuid())
  userId           String
  applicationId    String?
  goal             String
  researcherOutput String
  plannerOutput    String
  reviewerOutput   String
  finalOutput      String
  providerTrace    Json?
  createdAt        DateTime @default(now())

  user             User            @relation(fields: [userId], references: [id])
  application      JobApplication? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
  @@index([createdAt])
}

model PromptEvalRun {
  id            String   @id @default(cuid())
  userId        String
  applicationId String?
  task          String
  variants      Json
  outputs       Json
  scores        Json
  winnerIndex   Int?
  judgeTrace    Json?
  createdAt     DateTime @default(now())

  user          User            @relation(fields: [userId], references: [id])
  application   JobApplication? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([applicationId])
  @@index([createdAt])
}

model PersonalChatSession {
  id            String   @id @default(cuid())
  userId        String
  applicationId String?
  title         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id])
  application   JobApplication? @relation(fields: [applicationId], references: [id])
  messages      PersonalChatMessage[]

  @@index([userId])
  @@index([applicationId])
  @@index([updatedAt])
}

model PersonalChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  role       String
  content    String
  citations  Json?
  createdAt  DateTime @default(now())

  session    PersonalChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}
